# Server runtime
PORT=4000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Admin seed users
ADMIN_EMAIL=admin@skilldev.com
ADMIN_PASSWORD=admin123
SUB_ADMIN_EMAIL=subadmin@skilldev.com
SUB_ADMIN_PASSWORD=subadmin123
ADMIN_JWT_SECRET=replace-with-strong-secret

# Firebase Admin credentials (use one option)
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/serviceAccount.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional cache tuning (milliseconds)
DASHBOARD_CACHE_TTL_MS=30000
COURSE_LIST_CACHE_TTL_MS=60000
REPORTS_CACHE_TTL_MS=30000
